<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="40dp">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_launcher"
        android:background="@android:color/white"
        android:padding="8dp"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="언어팩 다운로드 중"
        android:textColor="#E6EDF3"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="준비 중..."
        android:textColor="#7D8590"
        android:textSize="16sp"
        android:layout_marginBottom="32dp"/>

    <ProgressBar
        android:id="@+id/progress_download"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_marginBottom="16dp"
        android:progressTint="#3FB950"
        android:progressBackgroundTint="#21262D"
        android:max="100"/>

    <TextView
        android:id="@+id/tv_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 / 2"
        android:textColor="#3FB950"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wi-Fi 또는 모바일 데이터가 필요합니다\n다운로드 후 오프라인으로 사용 가능합니다"
        android:textColor="#30363D"
        android:textSize="14sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"/>

</LinearLayout>
